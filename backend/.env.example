# Clave secreta para JWT y cifrado
SECRET_KEY=generate_with_openssl_rand_hex_32

# Credenciales de administrador inicial
ADMIN_USERNAME=your_admin_username
ADMIN_PASSWORD=your_secure_password_here

# Modo debug (true para desarrollo, false para producción)
DEBUG=false

# URL de la base de datos
# Para SQLite (desarrollo): sqlite:///./uocra.db
# Para PostgreSQL (producción): postgresql://user:pass@localhost/dbname
DATABASE_URL=sqlite:///./uocra.db

# Orígenes permitidos para CORS (separados por comas, sin espacios)
# Ejemplo: http://localhost:5173,https://tudominio.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# URL de Cloudflared (para túneles temporales, opcional)
CLOUDFLARED_URL=
